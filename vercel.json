{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "regions": ["sfo1"],
  "env": {
    "DATABASE_URL": {
      "description": "PostgreSQL connection string for Supabase"
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT signing"
    },
    "VITE_APP_ID": {
      "description": "Manus OAuth App ID"
    },
    "OAUTH_SERVER_URL": {
      "description": "Manus OAuth server URL"
    },
    "VITE_OAUTH_PORTAL_URL": {
      "description": "Manus OAuth portal URL"
    },
    "OWNER_OPEN_ID": {
      "description": "Owner's OpenID from Manus"
    },
    "OWNER_NAME": {
      "description": "Owner's name"
    },
    "BUILT_IN_FORGE_API_URL": {
      "description": "Manus built-in API URL"
    },
    "BUILT_IN_FORGE_API_KEY": {
      "description": "Manus built-in API key"
    },
    "VITE_FRONTEND_FORGE_API_URL": {
      "description": "Frontend Manus API URL"
    },
    "VITE_FRONTEND_FORGE_API_KEY": {
      "description": "Frontend Manus API key"
    },
    "VITE_ANALYTICS_ENDPOINT": {
      "description": "Analytics endpoint"
    },
    "VITE_ANALYTICS_WEBSITE_ID": {
      "description": "Analytics website ID"
    },
    "VITE_APP_TITLE": {
      "description": "Application title"
    },
    "VITE_APP_LOGO": {
      "description": "Application logo URL"
    }
  },
  "functions": {
    "server/_core/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
